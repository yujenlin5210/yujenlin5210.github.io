---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getCoverUrl } from '../../utils/getCoverUrl';
import CinematicProject from '../../components/CinematicProject.jsx';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => {
	const dateA = new Date(a.data.date || a.id.slice(0,10));
	const dateB = new Date(b.data.date || b.id.slice(0,10));
	return dateB.getTime() - dateA.getTime();
});
---

<Layout title="Selected Works - Yu-Jen Lin" description="A deep dive into my interactive experiences and AR/VR prototypes.">
  <div class="pt-20">
    <div class="container mx-auto px-6 mb-12">
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-slate-900 dark:text-white mb-4">
        Selected <span class="text-indigo-500">Works</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl font-light">
        A collection of interactive experiences spanning virtual reality, augmented reality, and physical installations.
      </p>
    </div>

    <div class="flex flex-col">
      {sortedProjects.map((project, index) => {
        const coverUrl = getCoverUrl('projects', project.data);
        return (
          <CinematicProject 
            client:visible 
            project={project} 
            coverUrl={coverUrl} 
            index={index} 
          />
        );
      })}
    </div>

    <div class="container mx-auto px-6 py-24 text-center">
      <h2 class="text-3xl font-bold mb-8 text-slate-900 dark:text-white">Want to see more experiments?</h2>
      <a href="/lab" class="inline-flex px-8 py-4 bg-indigo-600 text-white font-bold rounded-full hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-500/20">
        Visit The Lab
      </a>
    </div>
  </div>
</Layout>
