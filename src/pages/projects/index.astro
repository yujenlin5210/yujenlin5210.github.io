---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getCoverUrl } from '../../utils/getCoverUrl';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => {
	const dateA = new Date(a.data.date || a.id.slice(0,10));
	const dateB = new Date(b.data.date || b.id.slice(0,10));
	return dateB.getTime() - dateA.getTime();
});
---

<Layout title="Projects - Yu-Jen Lin" description="Portfolio of AR/VR applications and interactive experiences.">
	<section class="py-20 flex-grow">
		<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-slate-900 dark:text-white">Selected Works</h1>
		<p class="text-lg text-slate-600 dark:text-slate-400 mb-12 max-w-2xl font-light">A collection of interactive experiences spanning virtual reality, augmented reality, installations, and game development.</p>
		
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{sortedProjects.map((project) => {
				const coverUrl = getCoverUrl('projects', project.data);
				return (
				<a href={`/projects/${project.id}`} class="group block relative rounded-2xl overflow-hidden bg-slate-100 dark:bg-slate-900 aspect-video hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-indigo-500/50">
					{coverUrl ? (
						<img src={coverUrl} alt={project.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
					) : (
						<div class="w-full h-full flex items-center justify-center text-slate-400 bg-slate-200 dark:bg-slate-800 font-medium">No Image</div>
					)}
					<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
						<h3 class="text-xl font-bold text-white mb-2">{project.data.title}</h3>
						{project.data.description && <p class="text-slate-200 text-sm line-clamp-2">{project.data.description}</p>}
					</div>
				</a>
			)})}
		</div>
	</section>
</Layout>
