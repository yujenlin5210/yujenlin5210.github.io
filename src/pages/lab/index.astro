---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getCoverUrl } from '../../utils/getCoverUrl';
import LabRegistry from '../../components/LabRegistry.jsx';
import { compareEntriesByDateDesc } from '../../utils/content';

// Sort labs so the newest are first
const labsData = await getCollection('lab', ({ data }) => {
  return data.hidden !== true;
});
const sortedLabs = [...labsData].sort(compareEntriesByDateDesc).map(lab => ({
  ...lab,
  coverUrl: getCoverUrl('lab', lab.data)
}));
---

<Layout title="The Lab - Yu-Jen Lin" description="Playground for experimental interactive design and WebGL.">
	{/* Technical Blueprint Background */}
	<div class="fixed inset-0 z-0 pointer-events-none opacity-[0.03] dark:opacity-[0.07]" 
		 style={{ backgroundImage: 'radial-gradient(circle, currentColor 1px, transparent 1px)', backgroundSize: '32px 32px' }}>
	</div>

	<section class="relative z-10 py-20 flex-grow">
		<header class="mb-12">
			<div class="flex items-center gap-3 mb-4">
				<div class="w-12 h-[1px] bg-indigo-500"></div>
				<span class="text-xs font-mono font-bold tracking-[0.3em] text-indigo-500 uppercase">Interactive Archives</span>
			</div>
			<h1 class="text-5xl md:text-8xl font-black tracking-tighter mb-6 text-slate-900 dark:text-white">The Lab</h1>
			<p class="text-xl text-slate-500 dark:text-slate-400 max-w-2xl font-light leading-relaxed">
				A repository of native WebGL experiments, XR prototypes, and playful micro-interactions.
				<span class="block mt-4 text-sm font-mono text-slate-400 italic">// Current_Registry_Size: {sortedLabs.length} modules</span>
			</p>
		</header>
		
		<LabRegistry client:load labs={sortedLabs} />

		<div class="mt-24 pt-12 border-t border-slate-200 dark:border-slate-800 text-center">
			<p class="text-slate-400 font-mono text-xs uppercase tracking-widest animate-pulse">
				End of registry // more experiments pending
			</p>
		</div>
	</section>
</Layout>
