---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getCoverUrl } from '../../utils/getCoverUrl';
import { filterTags } from '../../utils/filterTags';
import DodgeGame from '../../components/DodgeGame.jsx';
import TimeArt from '../../components/TimeArt.jsx';

export async function getStaticPaths() {
  const labs = await getCollection('lab', ({ data }) => {
    return data.hidden !== true;
  });
  return labs.map(lab => ({
    params: { id: lab.id },
    props: { lab },
  }));
}

const { lab } = Astro.props;
const { Content } = await render(lab);
const coverUrl = getCoverUrl('lab', lab.data);
const ogImage = coverUrl && !coverUrl.endsWith('.mp4') ? coverUrl : undefined;
const cleanTags = filterTags(lab.data.tags);

const isDodge = lab.id === '2026-04-14-dodge';
const isTimeArt = lab.id.includes('time-art');
const isImmersiveStickmanLab = lab.id === '2026-04-21-stickman-rig-lab';
const isDodgeTutorial = lab.id === '2026-04-27-dodge-tutorial';
const isWide = isDodge || isTimeArt || isDodgeTutorial;
---

<Layout 
  title={`Lab: ${lab.data.title} - Yu-Jen Lin`} 
  description={lab.data.description}
  maxWidth={isWide ? "max-w-7xl" : "max-w-5xl"}
  image={ogImage}
>
  <div class:list={[
    'flex-grow w-full px-6',
    isImmersiveStickmanLab ? 'pt-20 pb-0' : 'py-20',
  ]}>
    
    {/* 1. Header Section (Centered & Narrow) */}
    <div class:list={[isImmersiveStickmanLab ? 'mx-auto' : 'max-w-4xl mx-auto']}>
      <header class="mb-12 text-center">
        <div class="inline-block px-3 py-1 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 font-mono text-xs tracking-widest uppercase font-bold rounded-full mb-4 border border-indigo-100 dark:border-indigo-800/50">Experimental Lab</div>
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4 leading-tight">{lab.data.title}</h1>
        {lab.data.description && <p class="text-xl text-slate-500 dark:text-slate-400 font-light mb-8 max-w-2xl mx-auto">{lab.data.description}</p>}
        
        <div class="flex flex-wrap justify-center gap-2 mb-12">
          {cleanTags.map((tag) => (
            <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 rounded-full text-[10px] uppercase tracking-widest text-slate-600 dark:text-slate-400 font-bold border border-slate-200 dark:border-slate-700">
              {tag}
            </span>
          ))}
        </div>
      </header>
    </div>

    {/* 2. Interactive Breakout Area (Wide - Only for specific posts) */}
    {isDodge && (
      <div class="max-w-[1200px] mx-auto mb-16">
        <DodgeGame client:load />
      </div>
    )}
    {isTimeArt && (
      <div class="max-w-[1200px] mx-auto mb-16">
        <TimeArt client:load />
      </div>
    )}
    
    {/* 3. Standard Content Area */}
    <div class={isDodgeTutorial ? "w-full" : "max-w-4xl mx-auto"}>
      {/* Show cover image only for standard posts (non-breakout) */}
      {!isWide && coverUrl && !lab.data.hideCover && (
        <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-2xl mb-12 border border-slate-200 dark:border-white/5 bg-slate-100 dark:bg-slate-900 relative group">
          {coverUrl.endsWith('.mp4') ? (
            <>
              <video 
                id="cover-video"
                src={coverUrl} 
                autoplay 
                muted 
                loop 
                playsinline 
                class="w-full h-full object-cover" 
              />
              <div 
                id="mute-toggle"
                class="absolute bottom-6 right-6 px-4 py-2 bg-black/60 backdrop-blur-xl rounded-full border border-white/20 text-white text-xs font-mono font-bold uppercase tracking-widest cursor-pointer hover:bg-black/80 hover:scale-105 active:scale-95 transition-all flex items-center gap-2 z-20 shadow-lg"
              >
                <span id="mute-icon" class="text-base">🔇</span>
                <span id="mute-text">Click to Unmute</span>
              </div>
            </>
          ) : (
            <img src={coverUrl} alt={lab.data.title} class="w-full h-full object-cover" />
          )}
        </div>
      )}

      <article class:list={[
        isImmersiveStickmanLab
          ? 'mx-auto mb-0'
          : isDodgeTutorial
            ? 'w-full mb-24'
            : 'prose dark:prose-invert prose-indigo mx-auto prose-img:rounded-xl prose-img:shadow-lg bg-slate-50 dark:bg-slate-950 mb-24',
      ]}>
        <Content />
      </article>
    </div>

  </div>
  <script is:inline>
    (() => {
      const setupKey = '__labCoverVideoMuteToggleSetup__';

      if (window[setupKey]) {
        window[setupKey]();
        return;
      }

      let cleanupToggle = () => {};

      const updateToggleState = (video, muteToggle, muteIcon, muteText) => {
        if (video.muted) {
          muteIcon.textContent = '🔇';
          muteText.textContent = 'Click to Unmute';
          muteToggle.classList.remove('bg-indigo-600/80');
          muteToggle.classList.add('bg-black/60');
          return;
        }

        muteIcon.textContent = '🔊';
        muteText.textContent = 'Sound ON';
        muteToggle.classList.remove('bg-black/60');
        muteToggle.classList.add('bg-indigo-600/80');
      };

      const teardownVideoMuteToggle = () => {
        cleanupToggle();
        cleanupToggle = () => {};
      };

      const setupVideoMuteToggle = () => {
        teardownVideoMuteToggle();

        const video = document.getElementById('cover-video');
        const muteToggle = document.getElementById('mute-toggle');
        const muteIcon = document.getElementById('mute-icon');
        const muteText = document.getElementById('mute-text');

        if (
          !(video instanceof HTMLVideoElement) ||
          !(muteToggle instanceof HTMLElement) ||
          !(muteIcon instanceof HTMLElement) ||
          !(muteText instanceof HTMLElement)
        ) {
          return;
        }

        const handleToggleClick = () => {
          video.muted = !video.muted;
          updateToggleState(video, muteToggle, muteIcon, muteText);
        };

        updateToggleState(video, muteToggle, muteIcon, muteText);
        video.play().catch(() => {});
        muteToggle.addEventListener('click', handleToggleClick);

        cleanupToggle = () => {
          muteToggle.removeEventListener('click', handleToggleClick);
        };
      };

      window[setupKey] = setupVideoMuteToggle;
      document.addEventListener('astro:page-load', setupVideoMuteToggle);
      document.addEventListener('astro:before-swap', teardownVideoMuteToggle);
      setupVideoMuteToggle();
    })();
  </script>
</Layout>
