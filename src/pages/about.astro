  {
    name: "Techart Group",
    url: "http://www.techartgroup.com",
    role: "Software Engineer",
    time: "Taipei, Taiwan | May 2012 - Aug 2013",
    description: [
      "Designed UX interaction flows and mockups, and implemented the prototypes into real products.",
      "Surveyed and implemented state-of-the-art research papers including computer vision and machine learning that suited different projects’ needs."
    ]
  }
];

const education = [
  {
    name: "University of Michigan, School of Information",
    role: "Three years of studies in pursuit of PhD (Human-Computer Interaction)",
    time: "Ann Arbor, MI | 2015 - 2017"
  },
  {
    name: "University of Michigan, School of Information",
    role: "M.S. in Information | UX Research & Design, Human-Computer Interaction",
    time: "Ann Arbor, MI | 2011 - 2014"
  },
  {
    name: "National Taiwan University",
    role: "B.S. in Electrical Engineering",
    time: "Taipei, Taiwan | 2005 - 2009"
  }
];

const teachingAndLeadership = [
  {
    name: "University of Michigan",
    role: "Teaching Assistant - Python and Web Develop",
    time: "Ann Arbor, MI | 2015 - 2017",
    description: [
      "Designed lab sections assignments that provided students hands-on experiences associated with lecture material.",
      "Delivered a range of teaching activities including tutorials directed towards the delivery of subjects at both undergraduate and graduate levels."
    ]
  },
  {
    name: "DOIIIT Maker Space @ UMSI",
    url: "https://doiiit.github.io",
    role: "Co-Founder",
    time: "Ann Arbor, MI | 2014 - 2017",
    description: [
      "Setup a hardware space to build up a maker culture in the School of Information.",
      "Consulted students on projects and coordinated machine tools including laser cutters, 3D-printers, and more."
    ]
  }
];

const skills = [
  {
    category: "Game Engines",
    items: ["Unity3D | C#", "Unreal | C++", "OpenFrameworks | C++", "Flash | ActionScript 3.0"]
  },
  {
    category: "Software Development",
    items: ["Android | Java", "iOS | Objective-C", "Computer Vision", "Machine Learning"]
  },
