---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Stickman from '../components/Stickman.jsx';

interface Props {
	title: string;
	description?: string;
	maxWidth?: string;
	image?: string;
}

const { title, description = "Yu-Jen Lin - Portfolio", maxWidth = "max-w-5xl", image = '/assets/images/meta.png' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/assets/images/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		{/* Open Graph / Facebook */}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site || Astro.url)} />

		{/* Twitter */}
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.site || Astro.url)} />

		<ClientRouter /></head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col selection:bg-indigo-500 selection:text-white dark:bg-slate-950 dark:text-slate-50">
		<div class="w-full bg-indigo-600 text-white text-center py-2 px-4 text-sm font-medium sticky top-0 z-[60]">
			🚧 This website is currently under construction. Some information may be incomplete. Please refer to my <a href="https://www.linkedin.com/in/yujenlin1/" class="underline hover:text-indigo-200 transition-colors">LinkedIn</a> for up-to-date details.
		</div>
		{(Astro.url.pathname === '/projects' || Astro.url.pathname === '/projects/') && <Stickman client:load />}
		<header class={`w-full ${maxWidth} mx-auto p-6 flex items-center justify-between sticky top-0 z-50 bg-slate-50/80 backdrop-blur-md dark:bg-slate-950/80`}>
			<a href="/" class="text-xl font-bold tracking-tight hover:text-indigo-500 transition-colors">YJ.</a>
			<nav class="flex gap-6 font-medium">
				<a href="/projects" class="hover:text-indigo-500 transition-colors">Projects</a>
				<a href="/lab" class="hover:text-indigo-500 transition-colors">Lab</a>
				<a href="/about" class="hover:text-indigo-500 transition-colors">About</a>
			</nav>
		</header>
		
		<main class={`flex-grow w-full ${maxWidth} mx-auto p-6 flex flex-col`}>
			<slot />
		</main>

		<footer class={`w-full ${maxWidth} mx-auto p-6 flex justify-between items-center text-sm text-slate-500 dark:text-slate-400`}>
			<p>&copy; {new Date().getFullYear()} Yu-Jen Lin</p>
			<div class="flex gap-4">
				<a href="https://github.com/yjlintw" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-500 transition-colors">GitHub</a>
				<a href="https://www.linkedin.com/in/yujenlin1/" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-500 transition-colors">LinkedIn</a>
			</div>
		</footer>
	</body>
</html>
