---
// src/components/dodge-tutorial/TutorialChapter.astro
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="mb-32 relative">
  <div class="flex flex-col lg:flex-row gap-12">
    {/* Left Column: Markdown Content */}
    <div class="w-full lg:w-1/2 prose dark:prose-invert prose-indigo prose-img:rounded-xl">
      <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-8 text-slate-900 dark:text-white">
        {title}
      </h2>
      <slot name="text" />
    </div>

    {/* Right Column: Sticky Canvas */}
    <div class="w-full lg:w-1/2 relative">
      <div class="sticky top-24 z-10 w-full aspect-square md:aspect-video lg:aspect-square bg-slate-100 dark:bg-slate-900 rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-white/10 flex items-center justify-center">
        <slot name="canvas" />
      </div>
    </div>
  </div>

  {/* Bottom Row: Sandpack Playground */}
  <div class="mt-16 w-full max-w-[1200px] mx-auto">
    <slot name="playground" />
  </div>
</section>
