---
interface Props {
  src: string;
  width?: string;
  height?: string;
  title?: string;
}

const { src, width = "100%", height = "600px", title = "Unity WebGL Build" } = Astro.props;
---

<div class="unity-embed-container my-8 w-full rounded-xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-800 bg-slate-900 flex justify-center items-center relative group" style={`height: ${height}; width: ${width};`}>
  <div class="absolute inset-0 flex items-center justify-center text-white/50 z-0">Loading Unity Experience...</div>
  <iframe
    src={src}
    title={title}
    class="w-full h-full relative z-10 border-0"
    allow="autoplay; fullscreen; vr"
    loading="lazy"
  ></iframe>
  <div class="absolute top-4 right-4 z-20 opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur text-white text-xs px-3 py-1.5 rounded-full pointer-events-none">
    Unity WebGL
  </div>
</div>
